# Database
DATABASE_URL=postgresql://user:password@localhost:5432/salesai

# AWS
AWS_REGION=us-east-1
S3_BUCKET_IMAGES=salesai-product-images

# Clerk Authentication
CLERK_DOMAIN=your-app.clerk.accounts.dev
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_AUDIENCE=  # Optional: leave empty for default

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_URL=https://your-api-gateway-url.amazonaws.com/api/telegram/webhook

# CORS
CORS_ORIGINS=["http://localhost:5173","https://your-frontend-domain.com"]
