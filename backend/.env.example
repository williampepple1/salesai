# Database
# Local and test environments must use PostgreSQL. SQLite is not supported.
DATABASE_URL=postgresql://user:password@localhost:5432/salesai
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/salesai_test

# Production should prefer Secrets Manager plus Lambda IAM instead of DATABASE_URL.
# DATABASE_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:salesai-db-credentials
ENVIRONMENT=development

# AWS
AWS_REGION=us-east-1
S3_BUCKET_IMAGES=salesai-product-images

# Clerk Authentication
CLERK_DOMAIN=your-app.clerk.accounts.dev
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_AUDIENCE=  # Optional: leave empty for default

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_URL=https://your-api-gateway-url.amazonaws.com/api/telegram/webhook
ENABLE_LOCAL_UPLOADS=false

# CORS
CORS_ORIGINS=["http://localhost:5173","https://your-frontend-domain.com"]
